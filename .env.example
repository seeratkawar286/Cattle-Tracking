# ─────────────────────────────────────────────
# sylCloud HCS048 Server — Environment Config
# Copy to .env and fill all values before deployment
# ─────────────────────────────────────────────

# Node environment — MUST be "production" on server
NODE_ENV=production

# REST API port (HTTP + WebSocket)
PORT=3000

# HCS048 TCP ingestion port (ear tags connect here)
TCP_PORT=8080

# Maximum simultaneous TCP connections from devices
TCP_MAX_CONNECTIONS=500

# Maximum TCP frame buffer size per connection (bytes)
# Protects against memory exhaustion from malformed/malicious data
TCP_MAX_BUFFER_BYTES=4096

# ─── MongoDB ─────────────────────────────────
# Use MongoDB Atlas URI for cloud deployment
MONGO_URI=mongodb://localhost:27017/sylcloud_cattle

# MongoDB connection pool size
MONGO_POOL_SIZE=10

# ─── JWT Authentication ───────────────────────
# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_64_BYTE_RANDOM_HEX_STRING

JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────
# Comma-separated list of allowed origins
# Example: https://app.sylcloud.com,https://dashboard.sylcloud.com
CORS_ORIGINS=http://localhost:3001

# ─── Rate Limiting ────────────────────────────
# Max API requests per IP per minute
RATE_LIMIT_MAX=100

# ─── Logging ──────────────────────────────────
# combined = Apache-style full log (production)
# dev      = coloured short log (development)
LOG_FORMAT=combined

# ─── HCS048 Protocol Thresholds ──────────────
SPEED_MOVING_THRESHOLD=1.5
SPEED_STATIONARY_THRESHOLD=0.5
